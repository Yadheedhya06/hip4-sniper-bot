# ── Required ──
HYPERLIQUID_PRIVATE_KEY=0xYOUR_AGENT_WALLET_KEY

# ── Required if using an agent wallet (recommended) ──
# Master wallet that holds USDH; the agent signs trades on its behalf.
# Authorize the agent in HL UI → Settings → API → Approve API Wallet first.
HL_ACCOUNT_ADDRESS=0xYOUR_MASTER_WALLET_ADDRESS

# ── Sizing (all optional; shown values are the defaults) ──
# Tuned for ~$800 equity → $80 baseline / $100 hard cap.
SIZE_PCT_OF_EQUITY=0.10            # 10% baseline → $80 at $800 equity
SIZE_MAX_PCT_OF_EQUITY=0.125       # 12.5% ceiling → $100 max
SIZE_MIN_USD=10
SIZE_MAX_USD=100                   # hard $ cap, applied last
EDGE_REFERENCE=0.10                # edge=ref → 1.0x size; clamped [0.6x, 2.0x]
MAX_OPEN_POSITIONS=3

# Hard cap per-trade USD regardless of equity. Empty/unset = disabled.
TRAINING_WHEELS_MAX_USD=

# Halt all trading when balance is below this floor.
EQUITY_FLOOR_USD=50

# ── Daily loss kill-switch ──
DAILY_LOSS_LIMIT_PCT=0.10
DAILY_STATE_FILE=daily_state.json

# ── Statistical gate (dynamic |d| floor) ──
# min_d_required = max(MIN_D_FLOOR, MIN_D_BASE * (time_left / MAX_TIME_LEFT_MIN))
# At t=5min → 1.8 (current behavior); t=2min → 0.72; t≤0.83min → 0.3 floor.
EDGE_THRESHOLD=0.10
MIN_D_BASE=1.8                     # MIN_ABS_D still works as a fallback alias
MIN_D_FLOOR=0.3
MAX_TIME_LEFT_MIN=5.0
IDEAL_TIME_LEFT_MIN=3.0

# ── Conviction gate (taker-buy volume + same-side bid depth) ──
# Required vol_ratio and depth_imb tighten as |d| weakens:
#   conf = min(1, |d| / MIN_D_BASE)
#   required = MAX − conf·(MAX − MIN)
# At |d|=MIN_D_BASE → MIN thresholds. At |d|→0 → MAX thresholds.
VOLUME_RATIO_MIN=1.5               # required when statistically very confident
VOLUME_RATIO_MAX=2.5               # required when |d| is near zero / pure-flow
DEPTH_IMB_MIN=0.60
DEPTH_IMB_MAX=0.70
VOLUME_LOOKBACK_MIN=10             # rolling window for taker-buy aggregation
DEPTH_PRICE_BAND_PCT=0.05          # ± of mid; bids outside the band don't count
DEPTH_FALLBACK_LEVELS=10           # if <DEPTH_MIN_QUALIFYING_LEVELS in band
DEPTH_MIN_QUALIFYING_LEVELS=3

# ── Pure-flow window (final 60-90s) ──
# Statistical floor relaxes; conviction thresholds clamp to MAX strictness.
# Refuses to trade if no taker-buy on favorable coin in PURE_FLOW_FRESHNESS_SEC.
PURE_FLOW_TIME_LEFT_MIN=1.5
PURE_FLOW_EDGE_THRESHOLD=0.05
PURE_FLOW_FRESHNESS_SEC=60

# ── Execution ──
MAX_SLIPPAGE_PCT=0.03
EDGE_PRESERVATION_MIN=0.80
USE_LIMIT_ORDERS=true

# ── Loops & cadence ──
DISCOVERY_INTERVAL_SEC=300
PRICE_POLL_INTERVAL_SEC=15         # idle cadence (no contract within window)
ACTIVE_POLL_INTERVAL_SEC=2         # snipe cadence inside MAX_TIME_LEFT_MIN
VOL_REFRESH_SEC=60                 # REST vol fallback (only if WS candle stale)
EQUITY_REFRESH_SEC=300
HEARTBEAT_SEC=300

# ── WebSocket ──
WS_RECONNECT_DELAY_SEC=5
WS_PING_INTERVAL_SEC=30            # app-level ping (HL closes idle conn at 60s)
WS_SUB_RECONCILE_SEC=5             # reconcile trades subs after discovery

# ── Ops ──
DRY_RUN=false                      # set true to log decisions without signing
LOG_TO_STDOUT=true
LOG_TO_FILE=false
LOG_LEVEL=INFO
PORT=8080                          # /health endpoint port (Railway sets this)
